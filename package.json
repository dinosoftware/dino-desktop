{
  "name": "dino-desktop",
  "version": "1.6.3",
  "description": "A modern OpenSubsonic music player",
  "author": "Dino Desktop",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "node dev.js",
    "build": "cd frontend && npm run build && cd .. && electron-builder",
    "build:dir": "cd frontend && npm run build && cd .. && electron-builder --dir",
    "build:linux": "cd frontend && npm run build && cd .. && electron-builder --linux",
    "build:linux:x64": "cd frontend && npm run build && cd .. && electron-builder --linux --x64",
    "build:linux:arm64": "cd frontend && npm run build && cd .. && electron-builder --linux --arm64"
  },
  "devDependencies": {
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.dino.desktop",
    "productName": "Dino Desktop",
    "files": [
      "main.js",
      "preload.js",
      "frontend/dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "dinosoftware",
      "repo": "dino-desktop"
    },
    "linux": {
      "artifactName": "dino-desktop-${version}-linux-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Audio",
      "icon": "build/appicon.png",
      "extraFiles": [
        {
          "from": "build/dino-desktop.desktop",
          "to": "."
        },
        {
          "from": "build/appicon.png",
          "to": "dino-desktop.png"
        }
      ]
    },
    "appImage": {
      "artifactName": "dino-desktop-${version}-${arch}.AppImage"
    },
    "win": {
      "target": "nsis",
      "icon": "build/appicon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.music",
      "icon": "build/appicon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.3",
    "electron-updater": "^6.8.3"
  }
}
